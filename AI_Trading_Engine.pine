//@version=6
indicator("Quantum AI Trading Engine (QATE)", shorttitle="QATE", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// =================================================================================================
// 1. INPUTS
// =================================================================================================
grp_ms    = "Market Structure Engine"
major_len = input.int(10, "Major Pivot Length", group=grp_ms, minval=2)
minor_len = input.int(3,  "Minor Pivot Length", group=grp_ms, minval=1)

grp_liq   = "Liquidity Engine"
liq_tol   = input.float(0.1, "Equal High/Low Tolerance %", group=grp_liq, step=0.01)

grp_inst  = "Institutional Engine"
ob_limit  = input.int(10, "Max Order Blocks Displayed", group=grp_inst, minval=1, maxval=100)
fvg_limit = input.int(10, "Max FVGs Displayed", group=grp_inst, minval=1, maxval=100)
fvg_min   = input.float(0.2, "Min FVG Size (ATR Multiplier)", group=grp_inst, step=0.1)

grp_trend = "Trend & Strength Engines"
ema_fast  = input.int(50, "Fast EMA Length", group=grp_trend)
ema_slow  = input.int(200, "Slow EMA Length", group=grp_trend)
adx_len   = input.int(14, "ADX Length", group=grp_trend)
adx_thresh= input.int(20, "ADX Trend Threshold", group=grp_trend)
vol_len   = input.int(20, "Volume SMA Length", group=grp_trend)
rvol_min  = input.float(1.2, "Min RVOL for Confirmation", group=grp_trend, step=0.1)

grp_risk  = "Risk Engine & Execution"
conf_min  = input.int(90, "Minimum Confidence Score", group=grp_risk, minval=0, maxval=100)
atr_len   = input.int(14, "ATR Length", group=grp_risk)
sl_atr_m  = input.float(1.5, "Stop Loss ATR Multiplier", group=grp_risk, step=0.1)
tp1_rr    = input.float(1.0, "TP1 Risk/Reward Ratio", group=grp_risk, step=0.1)
tp2_rr    = input.float(2.0, "TP2 Risk/Reward Ratio", group=grp_risk, step=0.1)
tp3_rr    = input.float(3.0, "TP3 Risk/Reward Ratio", group=grp_risk, step=0.1)
ts_atr_m  = input.float(2.0, "Trailing Stop ATR Multiplier (After TP2)", group=grp_risk, step=0.1)

// Aesthetic Colors
color_bull = color.new(#00E676, 0)
color_bear = color.new(#FF5252, 0)
color_fvg_bull = color.new(#00E676, 85)
color_fvg_bear = color.new(#FF5252, 85)
color_ob_bull = color.new(#2962FF, 75)
color_ob_bear = color.new(#AA00FF, 75)
color_bg = color.new(color.gray, 95)


// =================================================================================================
// 2. CUSTOM TYPES (UDTs)
// =================================================================================================
type SwingPoint
    int index
    float price
    bool is_high
    bool is_major

type OrderBlock
    int top_index
    float top
    float bottom
    bool is_bullish
    bool is_mitigated
    box b
    
type FVG
    int index
    float top
    float bottom
    bool is_bullish
    bool is_filled
    box b

type PositionState
    int status // 0: flat, 1: long, -1: short
    float entry_price
    float sl
    float tp1
    float tp2
    float tp3
    bool hit_tp1
    bool hit_tp2
    bool hit_tp3
    float trailing_stop
    
// =================================================================================================
// 3. GLOBAL STATE & CALCULATIONS
// =================================================================================================
var array<SwingPoint> major_swings = array.new<SwingPoint>()
var array<SwingPoint> minor_swings = array.new<SwingPoint>()

var array<OrderBlock> order_blocks = array.new<OrderBlock>()
var array<FVG> fvgs = array.new<FVG>()

var PositionState pos = PositionState.new(0, na, na, na, na, na, false, false, false, na)

float atr = ta.atr(atr_len)
float ema50 = ta.ema(close, ema_fast)
float ema200 = ta.ema(close, ema_slow)

// ADX Calculation
[di_plus, di_minus, adx] = ta.dmi(adx_len, adx_len)

// RVOL Calculation
float vol_sma = ta.sma(volume, vol_len)
float rvol = volume / (vol_sma == 0 ? 1 : vol_sma)

// =================================================================================================
// 4. MARKET STRUCTURE ENGINE
// =================================================================================================
// Detect Non-Repainting Pivots
float ph_major = ta.pivothigh(high, major_len, major_len)
float pl_major = ta.pivotlow(low, major_len, major_len)
float ph_minor = ta.pivothigh(high, minor_len, minor_len)
float pl_minor = ta.pivotlow(low, minor_len, minor_len)

bool is_ph_major = not na(ph_major)
bool is_pl_major = not na(pl_major)
bool is_ph_minor = not na(ph_minor)
bool is_pl_minor = not na(pl_minor)

if is_ph_major
    array.unshift(major_swings, SwingPoint.new(bar_index[major_len], high[major_len], true, true))
if is_pl_major
    array.unshift(major_swings, SwingPoint.new(bar_index[major_len], low[major_len], false, true))
    
if is_ph_minor
    array.unshift(minor_swings, SwingPoint.new(bar_index[minor_len], high[minor_len], true, false))
if is_pl_minor
    array.unshift(minor_swings, SwingPoint.new(bar_index[minor_len], low[minor_len], false, false))

// BOS and CHoCH Tracking
var int ms_bias = 0 // 1 for Bullish, -1 for Bearish
var float last_major_high = na
var float last_major_low = na

if array.size(major_swings) > 0
    for i = 0 to array.size(major_swings) - 1
        sp = array.get(major_swings, i)
        if sp.is_high and na(last_major_high)
            last_major_high := sp.price
        if not sp.is_high and na(last_major_low)
            last_major_low := sp.price
        if not na(last_major_high) and not na(last_major_low)
            break

bool bull_bos = false
bool bear_bos = false
bool bull_choch = false
bool bear_choch = false

if not na(last_major_high) and close > last_major_high and ms_bias <= 0
    bull_choch := true
    ms_bias := 1
    last_major_high := na // reset for next tracking
else if not na(last_major_high) and close > last_major_high and ms_bias == 1
    bull_bos := true
    last_major_high := na 

if not na(last_major_low) and close < last_major_low and ms_bias >= 0
    bear_choch := true
    ms_bias := -1
    last_major_low := na 
else if not na(last_major_low) and close < last_major_low and ms_bias == -1
    bear_bos := true
    last_major_low := na 

// =================================================================================================
// 5. LIQUIDITY ENGINE
// =================================================================================================
bool buy_sweep = false
bool sell_sweep = false

// Sweep is defined as price piercing the major swing level but failing to close beyond it.
if not na(last_major_high) and high > last_major_high and close < last_major_high
    buy_sweep := true

if not na(last_major_low) and low < last_major_low and close > last_major_low
    sell_sweep := true

// =================================================================================================
// 6. INSTITUTIONAL ENGINE (Order Blocks & Breakers)
// =================================================================================================
// Bullish OB: Last down-close candle before an upward MS break
if (bull_bos or bull_choch)
    int ob_index = na
    float ob_top = na
    float ob_bottom = na
    for i = 1 to 50
        if close[i] < open[i] // Down candle
            ob_index := bar_index[i]
            ob_top := high[i]
            ob_bottom := low[i]
            break
    if not na(ob_index)
        box b = box.new(ob_index, ob_top, bar_index, ob_bottom, border_color=color_bull, bgcolor=color_ob_bull, extend=extend.right)
        array.unshift(order_blocks, OrderBlock.new(ob_index, ob_top, ob_bottom, true, false, b))

// Bearish OB: Last up-close candle before a downward MS break
if (bear_bos or bear_choch)
    int ob_index = na
    float ob_top = na
    float ob_bottom = na
    for i = 1 to 50
        if close[i] > open[i] // Up candle
            ob_index := bar_index[i]
            ob_top := high[i]
            ob_bottom := low[i]
            break
    if not na(ob_index)
        box b = box.new(ob_index, ob_top, bar_index, ob_bottom, border_color=color_bear, bgcolor=color_ob_bear, extend=extend.right)
        array.unshift(order_blocks, OrderBlock.new(ob_index, ob_top, ob_bottom, false, false, b))

// Mitigate Order Blocks (Remove extension)
if array.size(order_blocks) > 0
    for i = array.size(order_blocks) - 1 to 0
        ob = array.get(order_blocks, i)
        if not ob.is_mitigated
            if ob.is_bullish and low < ob.bottom and bar_index > ob.top_index + 1
                ob.is_mitigated := true
                box.set_extend(ob.b, extend.none)
                box.set_right(ob.b, bar_index)
            if not ob.is_bullish and high > ob.top and bar_index > ob.top_index + 1
                ob.is_mitigated := true
                box.set_extend(ob.b, extend.none)
                box.set_right(ob.b, bar_index)

// Garbage Collection to respect drawing limits
if array.size(order_blocks) > ob_limit
    OrderBlock old_ob = array.pop(order_blocks)
    box.delete(old_ob.b)

// =================================================================================================
// 7. FAIR VALUE GAP ENGINE
// =================================================================================================
bool is_bull_fvg = low > high[2] and (low - high[2]) > (fvg_min * atr) and close[1] > open[1]
bool is_bear_fvg = high < low[2] and (low[2] - high) > (fvg_min * atr) and close[1] < open[1]

if is_bull_fvg
    box b = box.new(bar_index[2], low, bar_index, high[2], border_color=na, bgcolor=color_fvg_bull, extend=extend.right)
    array.unshift(fvgs, FVG.new(bar_index[2], low, high[2], true, false, b))

if is_bear_fvg
    box b = box.new(bar_index[2], low[2], bar_index, high, border_color=na, bgcolor=color_fvg_bear, extend=extend.right)
    array.unshift(fvgs, FVG.new(bar_index[2], low[2], high, false, false, b))

// Mitigate FVGs (Gap Fills)
if array.size(fvgs) > 0
    for i = array.size(fvgs) - 1 to 0
        f = array.get(fvgs, i)
        if not f.is_filled
            if f.is_bullish and low <= f.bottom
                f.is_filled := true
                box.set_extend(f.b, extend.none)
                box.set_right(f.b, bar_index)
            if not f.is_bullish and high >= f.top
                f.is_filled := true
                box.set_extend(f.b, extend.none)
                box.set_right(f.b, bar_index)

if array.size(fvgs) > fvg_limit
    FVG old_fvg = array.pop(fvgs)
    box.delete(old_fvg.b)

// =================================================================================================
// 8. PROBABILITY ENGINE
// =================================================================================================
int conf_score_bull = 0
int conf_score_bear = 0

// Trend Alignment (Max 20 pts)
if ema50 > ema200 and close > ema50
    conf_score_bull += 20
if ema50 < ema200 and close < ema50
    conf_score_bear += 20

// Momentum & Strength (Max 20 pts)
if adx > adx_thresh
    if di_plus > di_minus
        conf_score_bull += 10
    else if di_minus > di_plus
        conf_score_bear += 10
if rvol > rvol_min
    conf_score_bull += 10
    conf_score_bear += 10

// Market Structure Alignment (Max 20 pts)
if ms_bias == 1
    conf_score_bull += 20
if ms_bias == -1
    conf_score_bear += 20

// Liquidity Sweep (Max 20 pts)
if sell_sweep
    conf_score_bull += 20
if buy_sweep
    conf_score_bear += 20

// Zone Proximity (Fresh OB/FVG) (Max 20 pts)
bool in_bull_zone = false
bool in_bear_zone = false

if array.size(order_blocks) > 0
    for i = 0 to math.min(array.size(order_blocks) - 1, 5)
        ob = array.get(order_blocks, i)
        if not ob.is_mitigated
            if ob.is_bullish and low <= ob.top and close >= ob.bottom
                in_bull_zone := true
            if not ob.is_bullish and high >= ob.bottom and close <= ob.top
                in_bear_zone := true

if array.size(fvgs) > 0
    for i = 0 to math.min(array.size(fvgs) - 1, 5)
        f = array.get(fvgs, i)
        if not f.is_filled
            if f.is_bullish and low <= f.top and close >= f.bottom
                in_bull_zone := true
            if not f.is_bullish and high >= f.bottom and close <= f.top
                in_bear_zone := true

if in_bull_zone
    conf_score_bull += 20
if in_bear_zone
    conf_score_bear += 20

// =================================================================================================
// 9. RISK ENGINE & ENTRY LOGIC
// =================================================================================================
bool buy_signal = conf_score_bull >= conf_min and pos.status != 1
bool sell_signal = conf_score_bear >= conf_min and pos.status != -1

// Position Management Loop
if pos.status != 0
    // SL Hit Logic
    if (pos.status == 1 and low <= pos.sl) or (pos.status == -1 and high >= pos.sl)
        pos.status := 0
        alert("QATE: Stop Loss Hit! Closing position.", alert.freq_once_per_bar_close)
    
    // TP & Trailing Stop Logic (Long)
    if pos.status == 1 
        if high >= pos.tp3 and not pos.hit_tp3
            pos.hit_tp3 := true
            pos.status := 0
            alert("QATE: TP3 Hit! Trade completed successfully.", alert.freq_once_per_bar_close)
        else if high >= pos.tp2 and not pos.hit_tp2
            pos.hit_tp2 := true
            pos.trailing_stop := low - (atr * ts_atr_m)
            pos.sl := math.max(pos.sl, pos.trailing_stop)
            alert("QATE: TP2 Hit! ATR Trailing Stop Activated.", alert.freq_once_per_bar_close)
        else if high >= pos.tp1 and not pos.hit_tp1
            pos.hit_tp1 := true
            pos.sl := math.max(pos.sl, pos.entry_price) 
            alert("QATE: TP1 Hit! Stop Loss moved to Break-Even.", alert.freq_once_per_bar_close)
            
        // Process Trailing Stop Step
        if pos.hit_tp2
            float new_trail = low - (atr * ts_atr_m)
            pos.trailing_stop := math.max(pos.trailing_stop, new_trail)
            pos.sl := math.max(pos.sl, pos.trailing_stop)

    // TP & Trailing Stop Logic (Short)
    if pos.status == -1 
        if low <= pos.tp3 and not pos.hit_tp3
            pos.hit_tp3 := true
            pos.status := 0
            alert("QATE: TP3 Hit! Trade completed successfully.", alert.freq_once_per_bar_close)
        else if low <= pos.tp2 and not pos.hit_tp2
            pos.hit_tp2 := true
            pos.trailing_stop := high + (atr * ts_atr_m)
            pos.sl := math.min(pos.sl, pos.trailing_stop)
            alert("QATE: TP2 Hit! ATR Trailing Stop Activated.", alert.freq_once_per_bar_close)
        else if low <= pos.tp1 and not pos.hit_tp1
            pos.hit_tp1 := true
            pos.sl := math.min(pos.sl, pos.entry_price)
            alert("QATE: TP1 Hit! Stop Loss moved to Break-Even.", alert.freq_once_per_bar_close)

        // Process Trailing Stop Step
        if pos.hit_tp2
            float new_trail = high + (atr * ts_atr_m)
            pos.trailing_stop := math.min(pos.trailing_stop, new_trail)
            pos.sl := math.min(pos.sl, pos.trailing_stop)

// Trade Entry Execution
if buy_signal
    pos.status := 1
    pos.entry_price := close
    pos.sl := low - (atr * sl_atr_m)
    float risk = pos.entry_price - pos.sl
    pos.tp1 := pos.entry_price + (risk * tp1_rr)
    pos.tp2 := pos.entry_price + (risk * tp2_rr)
    pos.tp3 := pos.entry_price + (risk * tp3_rr)
    pos.hit_tp1 := false
    pos.hit_tp2 := false
    pos.hit_tp3 := false
    pos.trailing_stop := na
    alert("QATE BUY Signal. Confidence: " + str.tostring(conf_score_bull) + "% | Entry: " + str.tostring(pos.entry_price), alert.freq_once_per_bar_close)

if sell_signal
    pos.status := -1
    pos.entry_price := close
    pos.sl := high + (atr * sl_atr_m)
    float risk = pos.sl - pos.entry_price
    pos.tp1 := pos.entry_price - (risk * tp1_rr)
    pos.tp2 := pos.entry_price - (risk * tp2_rr)
    pos.tp3 := pos.entry_price - (risk * tp3_rr)
    pos.hit_tp1 := false
    pos.hit_tp2 := false
    pos.hit_tp3 := false
    pos.trailing_stop := na
    alert("QATE SELL Signal. Confidence: " + str.tostring(conf_score_bear) + "% | Entry: " + str.tostring(pos.entry_price), alert.freq_once_per_bar_close)

// =================================================================================================
// 10. VISUALIZATION ENGINE
// =================================================================================================
plotshape(buy_signal, title="Buy Signal", text="BUY", location=location.belowbar, style=shape.labelup, size=size.small, color=color_bull, textcolor=color.white)
plotshape(sell_signal, title="Sell Signal", text="SELL", location=location.abovebar, style=shape.labeldown, size=size.small, color=color_bear, textcolor=color.white)

// Target Lines for Active Trade
var line line_entry = na
var line line_sl = na
var line line_tp1 = na
var line line_tp2 = na
var line line_tp3 = na

if pos.status != 0
    if na(line_entry)
        line_entry := line.new(bar_index, pos.entry_price, bar_index+1, pos.entry_price, color=color.blue, style=line.style_dashed, width=2)
        line_sl := line.new(bar_index, pos.sl, bar_index+1, pos.sl, color=color.red, style=line.style_solid, width=2)
        line_tp1 := line.new(bar_index, pos.tp1, bar_index+1, pos.tp1, color=color.gray, style=line.style_dotted, width=1)
        line_tp2 := line.new(bar_index, pos.tp2, bar_index+1, pos.tp2, color=color.gray, style=line.style_dotted, width=1)
        line_tp3 := line.new(bar_index, pos.tp3, bar_index+1, pos.tp3, color=color.green, style=line.style_solid, width=2)
    else
        line.set_x2(line_entry, bar_index+1)
        line.set_y2(line_entry, pos.entry_price)
        line.set_y1(line_entry, pos.entry_price)
        
        line.set_x2(line_sl, bar_index+1)
        line.set_y2(line_sl, pos.sl)
        line.set_y1(line_sl, pos.sl)
        
        line.set_x2(line_tp1, bar_index+1)
        line.set_y2(line_tp1, pos.tp1)
        line.set_y1(line_tp1, pos.tp1)
        
        line.set_x2(line_tp2, bar_index+1)
        line.set_y2(line_tp2, pos.tp2)
        line.set_y1(line_tp2, pos.tp2)
        
        line.set_x2(line_tp3, bar_index+1)
        line.set_y2(line_tp3, pos.tp3)
        line.set_y1(line_tp3, pos.tp3)
else
    if not na(line_entry)
        line.delete(line_entry)
        line.delete(line_sl)
        line.delete(line_tp1)
        line.delete(line_tp2)
        line.delete(line_tp3)
        line_entry := na
        line_sl := na
        line_tp1 := na
        line_tp2 := na
        line_tp3 := na

// Dashboard HUD Table
var table dashboard = table.new(position.bottom_right, 2, 4, border_width=1, border_color=color.black)
if barstate.islast
    table.cell(dashboard, 0, 0, "QATE Dashboard", text_color=color.white, bgcolor=color.black, text_size=size.small)
    table.cell(dashboard, 1, 0, "Score", text_color=color.white, bgcolor=color.black, text_size=size.small)
    
    table.cell(dashboard, 0, 1, "Bull Confidence", text_color=color.white, bgcolor=color_bg, text_size=size.small)
    table.cell(dashboard, 1, 1, str.tostring(conf_score_bull) + "%", text_color=color.white, bgcolor=conf_score_bull >= conf_min ? color_bull : color_bg, text_size=size.small)
    
    table.cell(dashboard, 0, 2, "Bear Confidence", text_color=color.white, bgcolor=color_bg, text_size=size.small)
    table.cell(dashboard, 1, 2, str.tostring(conf_score_bear) + "%", text_color=color.white, bgcolor=conf_score_bear >= conf_min ? color_bear : color_bg, text_size=size.small)
    
    string pos_text = pos.status == 1 ? "LONG ACTIVE" : (pos.status == -1 ? "SHORT ACTIVE" : "FLAT")
    color pos_col = pos.status == 1 ? color_bull : (pos.status == -1 ? color_bear : color.gray)
    table.cell(dashboard, 0, 3, "Trade Status", text_color=color.white, bgcolor=color_bg, text_size=size.small)
    table.cell(dashboard, 1, 3, pos_text, text_color=color.white, bgcolor=pos_col, text_size=size.small)

// =================================================================================================
// 11. ALERT ENGINE
// =================================================================================================
// Alerts are integrated directly into the Risk Engine using alert() which executes non-repainting messages dynamically based on state.
